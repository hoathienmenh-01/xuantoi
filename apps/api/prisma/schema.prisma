// Xuân Tôi — Prisma schema MVP.
// Mở rộng theo từng phase. MVP hiện tại bao gồm:
//   - Auth: User, RefreshToken, LoginAttempt
//   - Character core: Character, Sect (nguyên skeleton)
//   - Game systems nền: GameLog, CurrencyLedger, RewardClaimLog, AdminAuditLog

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLAYER
  MOD
  ADMIN
}

enum Quality {
  PHAM
  LINH
  HUYEN
  TIEN
  THAN
}

enum ItemType {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  PILL
  HERB
  ORE
  KEY
  ARTIFACT
  MISC
}

enum EquipSlot {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  ARTIFACT_1
  ARTIFACT_2
  ARTIFACT_3
}

enum Difficulty {
  THUONG
  KHO
  AC_MONG
  BAO_TAU
}

enum TopupStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GameLogType {
  info
  success
  warning
  error
  system
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  passwordVersion Int       @default(1)
  role            Role      @default(PLAYER)
  banned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?

  character       Character?
  refreshTokens   RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 của refresh token (raw token chỉ tồn tại trong cookie HTTP-only client).
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  ip        String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

model Character {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String   @unique
  realmKey         String   @default("luyen_khi")
  realmStage       Int      @default(1)
  title            String?
  exp              BigInt   @default(0)
  level            Int      @default(1)

  hp               Int      @default(100)
  hpMax            Int      @default(100)
  mp               Int      @default(50)
  mpMax            Int      @default(50)
  stamina          Int      @default(100)
  staminaMax       Int      @default(100)
  power            Int      @default(10)
  spirit           Int      @default(10)
  speed            Int      @default(10)
  luck             Int      @default(5)
  daoVan           Int      @default(0)

  linhThach        BigInt   @default(0)
  tienNgoc         Int      @default(0)
  tienNgocKhoa     Int      @default(0)
  tienTe           Int      @default(0)
  nguyenThach      Int      @default(0)
  congHien         Int      @default(0)
  congDuc          Int      @default(0)
  chienCongTongMon Int      @default(0)

  settings         Json     @default("{}")
  cultivating      Boolean  @default(false)
  /// Thời điểm bắt đầu phiên tu luyện hiện tại (null khi không tu luyện).
  cultivationStartedAt DateTime?
  /// Mốc thời gian gần nhất EXP tu luyện đã được flush vào DB.
  lastCultivationAt    DateTime?

  sectId           String?
  sect             Sect?    @relation(fields: [sectId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  logs             GameLog[]
  currencyLedger   CurrencyLedger[]
  rewardClaims     RewardClaimLog[]
}

model Sect {
  id                String      @id @default(cuid())
  name              String      @unique
  level             Int         @default(1)
  treasuryLinhThach BigInt      @default(0)
  characters        Character[]
  createdAt         DateTime    @default(now())
}

model GameLog {
  id        String      @id @default(cuid())
  charId    String
  character Character   @relation(fields: [charId], references: [id], onDelete: Cascade)
  type      GameLogType
  text      String
  createdAt DateTime    @default(now())

  @@index([charId, createdAt])
}

model CurrencyLedger {
  id           String    @id @default(cuid())
  charId       String
  character    Character @relation(fields: [charId], references: [id], onDelete: Cascade)
  /// linhThach | tienNgoc | tienNgocKhoa | tienTe | nguyenThach | congHien | congDuc | chienCongTongMon
  currencyKey  String
  /// Có dấu: dương = cộng, âm = trừ.
  amount       BigInt
  balanceAfter BigInt
  reason       String
  refType      String?
  refId        String?
  createdAt    DateTime  @default(now())

  @@index([charId, createdAt])
  @@index([currencyKey, createdAt])
}

model RewardClaimLog {
  id         String    @id @default(cuid())
  charId     String
  character  Character @relation(fields: [charId], references: [id], onDelete: Cascade)
  rewardType String
  rewardKey  String
  refId      String
  createdAt  DateTime  @default(now())

  @@unique([charId, rewardType, rewardKey, refId])
  @@index([charId, createdAt])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminUserId  String
  targetUserId String?
  action       String
  beforeJson   Json?
  afterJson    Json?
  reason       String?
  ip           String?
  createdAt    DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId, createdAt])
}
