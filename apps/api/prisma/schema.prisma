// Xuân Tôi — schema rút gọn (file 04 §3). Sẽ mở rộng theo từng phase.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLAYER
  MOD
  ADMIN
}

enum Quality {
  PHAM
  LINH
  HUYEN
  TIEN
  THAN
}

enum ItemType {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  PILL
  HERB
  ORE
  KEY
  ARTIFACT
  MISC
}

enum EquipSlot {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  ARTIFACT_1
  ARTIFACT_2
  ARTIFACT_3
}

enum Difficulty {
  THUONG
  KHO
  AC_MONG
  BAO_TAU
}

enum TopupStatus {
  PENDING
  APPROVED
  REJECTED
}

model TopupOrder {
  id            String      @id @default(cuid())
  userId        String
  packageKey    String
  tienNgocAmount Int
  priceVND      Int
  /// Mã chuyển khoản hiển thị cho user khi quét QR (ví dụ TOPUP-<short>).
  transferCode  String      @unique
  status        TopupStatus @default(PENDING)
  note          String      @default("")
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  /// JSON describing the action target (e.g. user id, amount, reason).
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  passwordVersion Int       @default(1)
  role            Role      @default(PLAYER)
  banned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?

  character       Character?
}

model Character {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String   @unique
  realmKey         String
  realmStage       Int      @default(1)
  title            String?
  exp              BigInt   @default(0)
  level            Int      @default(1)

  hp               Int      @default(100)
  hpMax            Int      @default(100)
  mp               Int      @default(50)
  mpMax            Int      @default(50)
  stamina          Int      @default(100)
  staminaMax       Int      @default(100)
  power            Int      @default(10)
  spirit           Int      @default(10)
  speed            Int      @default(10)
  luck             Int      @default(5)
  daoVan           Int      @default(0)

  linhThach        BigInt   @default(0)
  tienNgoc         Int      @default(0)
  tienNgocKhoa     Int      @default(0)
  tienTe           Int      @default(0)
  nguyenThach      Int      @default(0)
  congHien         Int      @default(0)
  congDuc          Int      @default(0)
  chienCongTongMon Int      @default(0)

  settings         Json     @default("{}")
  cultivating      Boolean  @default(false)

  sectId           String?
  sect             Sect?    @relation(fields: [sectId], references: [id])

  inventory        InventoryItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InventoryItem {
  id            String     @id @default(cuid())
  characterId   String
  character     Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey       String
  qty           Int        @default(1)
  equippedSlot  EquipSlot?
  createdAt     DateTime   @default(now())

  @@index([characterId, itemKey])
  @@unique([characterId, equippedSlot])
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model Listing {
  id             String        @id @default(cuid())
  sellerId       String
  itemKey        String
  itemKind       String
  qty            Int
  pricePerUnit   BigInt
  status         ListingStatus @default(ACTIVE)
  buyerId        String?
  createdAt      DateTime      @default(now())
  soldAt         DateTime?

  @@index([status, itemKind])
  @@index([status, itemKey])
  @@index([sellerId, status])
}

model Sect {
  id                String      @id @default(cuid())
  name              String      @unique
  description       String      @default("")
  level             Int         @default(1)
  treasuryLinhThach BigInt      @default(0)
  leaderId          String?     @unique
  characters        Character[]
  createdAt         DateTime    @default(now())
}

enum ChatChannel {
  WORLD
  SECT
}

model ChatMessage {
  id         String      @id @default(cuid())
  channel    ChatChannel
  /// scopeKey: with WORLD = 'world'; with SECT = sectId
  scopeKey   String
  senderId   String
  senderName String
  text       String
  createdAt  DateTime    @default(now())

  @@index([channel, scopeKey, createdAt])
}

enum BossStatus {
  ACTIVE
  DEFEATED
  EXPIRED
}

model WorldBoss {
  id           String     @id @default(cuid())
  bossKey      String
  name         String
  level        Int
  maxHp        BigInt
  currentHp    BigInt
  status       BossStatus @default(ACTIVE)
  spawnedAt    DateTime   @default(now())
  expiresAt    DateTime
  defeatedAt   DateTime?
  rewardTotal  BigInt     @default(0)

  damages      BossDamage[]

  @@index([status, spawnedAt])
}

model BossDamage {
  id           String     @id @default(cuid())
  bossId       String
  boss         WorldBoss  @relation(fields: [bossId], references: [id], onDelete: Cascade)
  characterId  String
  characterName String
  totalDamage  BigInt     @default(0)
  hits         Int        @default(0)
  lastHitAt    DateTime   @default(now())

  @@unique([bossId, characterId])
  @@index([bossId, totalDamage])
}

enum EncounterStatus {
  ACTIVE
  WON
  LOST
  ABANDONED
}

model Encounter {
  id          String          @id @default(cuid())
  characterId String
  dungeonKey  String
  status      EncounterStatus @default(ACTIVE)
  /// JSON state: { monsterIndex, monsterHp, lastTurn }
  state       Json            @default("{}")
  /// JSON list of log lines [{ side, text, ts }]
  log         Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([characterId, status])
}
