// Xuân Tôi — schema rút gọn (file 04 §3). Sẽ mở rộng theo từng phase.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLAYER
  MOD
  ADMIN
}

enum Quality {
  PHAM
  LINH
  HUYEN
  TIEN
  THAN
}

enum ItemType {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  PILL
  HERB
  ORE
  KEY
  ARTIFACT
  MISC
}

enum EquipSlot {
  WEAPON
  ARMOR
  BELT
  BOOTS
  HAT
  TRAM
  ARTIFACT_1
  ARTIFACT_2
  ARTIFACT_3
}

enum Difficulty {
  THUONG
  KHO
  AC_MONG
  BAO_TAU
}

enum TopupStatus {
  PENDING
  APPROVED
  REJECTED
}

model TopupOrder {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation("TopupOrderUser", fields: [userId], references: [id], onDelete: Cascade)
  packageKey     String
  tienNgocAmount Int
  priceVND       Int
  /// Mã chuyển khoản hiển thị cho user khi quét QR (ví dụ TOPUP-<short>).
  transferCode   String      @unique
  status         TopupStatus @default(PENDING)
  note           String      @default("")
  approvedById   String?
  approvedBy     User?       @relation("TopupOrderApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  createdAt      DateTime    @default(now())

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actor       User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  action      String
  /// JSON describing the action target (e.g. user id, amount, reason).
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  passwordVersion Int       @default(1)
  role            Role      @default(PLAYER)
  banned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?

  character           Character?
  topupOrders         TopupOrder[]         @relation("TopupOrderUser")
  topupApprovals      TopupOrder[]         @relation("TopupOrderApprover")
  auditLogs           AdminAuditLog[]      @relation("AdminAuditActor")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
}

/// Token đặt lại mật khẩu (forgot/reset-password flow).
/// Token plaintext không bao giờ lưu trong DB; chỉ lưu argon2id hash.
/// Token TTL ngắn (mặc định 30 phút). One-shot consume.
model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// argon2id hash của reset token plaintext.
  hashedToken String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

model RefreshToken {
  id              String    @id @default(cuid())
  jti             String    @unique
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// argon2id hash của refresh JWT (không lưu plaintext).
  hashedToken     String
  passwordVersion Int
  expiresAt       DateTime
  revokedAt       DateTime?
  rotatedFromId   String?
  createdAt       DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, ip, createdAt])
  @@index([createdAt])
}

model Character {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String  @unique
  realmKey   String
  realmStage Int     @default(1)
  title      String?
  exp        BigInt  @default(0)
  level      Int     @default(1)

  hp         Int @default(100)
  hpMax      Int @default(100)
  mp         Int @default(50)
  mpMax      Int @default(50)
  stamina    Int @default(100)
  staminaMax Int @default(100)
  power      Int @default(10)
  spirit     Int @default(10)
  speed      Int @default(10)
  luck       Int @default(5)
  daoVan     Int @default(0)

  linhThach        BigInt @default(0)
  tienNgoc         Int    @default(0)
  tienNgocKhoa     Int    @default(0)
  tienTe           Int    @default(0)
  nguyenThach      Int    @default(0)
  congHien         Int    @default(0)
  congDuc          Int    @default(0)
  chienCongTongMon Int    @default(0)

  settings    Json    @default("{}")
  cultivating Boolean @default(false)

  /// Phase 11.3.A — Linh căn / Spiritual Root server-authoritative.
  /// `spiritualRootGrade` ∈ {'pham','linh','huyen','tien','than'} (5-tier).
  /// `primaryElement` ∈ Ngũ Hành {'kim','moc','thuy','hoa','tho'}.
  /// `secondaryElements` String[] = subset Ngũ Hành (size match grade tier).
  /// `rootPurity` 0-100 — tinh khiết linh căn, future Phase 11.3.B sẽ wire vào refine/reroll cost.
  /// `rootRerollCount` int counter — anti-spam reroll, idempotency key cho future reroll service.
  /// Nullable cho legacy character pre-Phase 11.3 (auto-roll lazy on first read).
  spiritualRootGrade String?
  primaryElement     String?
  secondaryElements  String[] @default([])
  rootPurity         Int      @default(100)
  rootRerollCount    Int      @default(0)

  /// Phase 11.1.B — Cultivation Method server-authoritative.
  /// `equippedCultivationMethodKey` = method đang trang bị (compose `expMultiplier`
  /// vào `CultivationProcessor.process()`). Nullable cho legacy character pre-11.1.B
  /// (multiplier fallback 1.0). Onboard phase 11.1.B sẽ auto-grant + auto-equip
  /// `khai_thien_quyet` starter.
  equippedCultivationMethodKey String?

  /// Phase 11.6.B Tribulation MVP — server-authoritative deterministic kiếp.
  /// `tribulationCooldownAt` set khi attempt FAIL → block retry tới khi
  /// `now >= tribulationCooldownAt`. Cleared khi SUCCESS (realm advance).
  /// `taoMaUntil` set khi FAIL + RNG roll dưới `taoMaDebuffChance` →
  /// Tâm Ma debuff active. Future Phase 11.8 (Buff runtime) sẽ áp dụng
  /// modifier vào combat. MVP chỉ persist + audit.
  tribulationCooldownAt DateTime?
  taoMaUntil            DateTime?

  sectId String?
  sect   Sect?   @relation(fields: [sectId], references: [id])

  inventory                   InventoryItem[]
  ledger                      CurrencyLedger[]
  itemLedger                  ItemLedger[]
  missionProgress             MissionProgress[]
  mails                       Mail[]
  dailyLoginClaims            DailyLoginClaim[]
  spiritualRootRollLogs       SpiritualRootRollLog[]
  cultivationMethods          CharacterCultivationMethod[]
  characterSkills             CharacterSkill[]
  tribulationAttemptLogs      TribulationAttemptLog[]
  buffs                       CharacterBuff[]
  talents                     CharacterTalent[]
  titleUnlocks                CharacterTitleUnlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Phase 11.3.A — Audit log cho mỗi lần roll Linh căn (onboard auto + future
/// manual reroll bằng `linh_can_dan` Phase 11.3.B). Idempotency: server-side
/// chống double-roll bằng query `findFirst({ characterId, source })` trước khi
/// roll mới (chỉ 1 row source='onboard' per character).
model SpiritualRootRollLog {
  id                        String    @id @default(cuid())
  characterId               String
  character                 Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Source: `onboard` (auto-roll khi tạo character) | `reroll` (manual qua item).
  source                    String
  /// Grade trước khi roll (null nếu lần đầu onboard).
  previousGrade             String?
  newGrade                  String
  /// Element trước khi roll (null nếu lần đầu onboard).
  previousElement           String?
  newElement                String
  /// Số element phụ trước/sau (validate match grade tier).
  previousSecondaryElements String[]  @default([])
  newSecondaryElements      String[]  @default([])
  /// Purity trước/sau roll.
  previousPurity            Int?
  newPurity                 Int
  /// Seed RNG (test deterministic) — nullable nếu dùng Math.random.
  rngSeed                   String?
  rolledAt                  DateTime  @default(now())

  @@index([characterId, source])
  @@index([rolledAt])
}

/// Phase 11.1.B — Sổ tay công pháp đã học của character. Mỗi cặp
/// (characterId, methodKey) duy nhất 1 row. `learn(...)` rely on `@@unique`
/// để đảm bảo idempotency (P2002 → return existing). `equip()` chỉ set
/// `Character.equippedCultivationMethodKey` chứ không sửa row này.
model CharacterCultivationMethod {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `CULTIVATION_METHODS` trong `packages/shared/src/cultivation-methods.ts`.
  methodKey   String
  /// Nguồn học method: `starter` (auto-grant onboard) | `dungeon_drop` |
  /// `boss_drop` | `sect_shop` | `event` | `quest_milestone` | `admin_grant`.
  /// Khớp với `CultivationMethodSource` (nhưng dùng String để forward-compat
  /// thêm source mới khi cần).
  source      String
  learnedAt   DateTime  @default(now())

  @@unique([characterId, methodKey])
  @@index([characterId])
}

/// Phase 11.2.B — Skill mastery progression. Mỗi cặp (characterId, skillKey)
/// duy nhất 1 row. `learn()` rely on `@@unique` cho idempotency (P2002 →
/// return existing). `upgradeMastery()` increment `masteryLevel` + deduct
/// LinhThach via CurrencyLedger. `equip()` toggle `isEquipped` (cap số skill
/// active đồng thời). Combat runtime đọc row này để compose
/// `applyMasteryEffect(template, masteryLevel, baseSkill)` thay vì dùng
/// SkillDef thô. Legacy character (không row) → masteryLevel=0 → hành vi
/// identical baseline pre-11.2.B.
model CharacterSkill {
  id           String    @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `SKILLS` trong `packages/shared/src/combat.ts` + `SKILL_TEMPLATES`
  /// trong `packages/shared/src/skill-templates.ts` (1-1 mapping).
  skillKey     String
  /// Level mastery hiện tại — 1 sau khi `learn`, increment bởi
  /// `upgradeMastery`, clamp tới `SKILL_TIER_DEFS[tier].maxMastery`.
  masteryLevel Int       @default(1)
  /// Skill có đang được trang bị (active slot) hay không. Cap MVP = 4 active
  /// đồng thời (kiểm tra trong service `equip`).
  isEquipped   Boolean   @default(false)
  /// Nguồn học skill: `starter` (basic_attack auto-grant) | `realm_unlock`
  /// (đột phá tự động học skill mở khi đạt realm) | `sect_shop` | `quest_milestone`
  /// | `boss_drop` | `event` | `admin_grant`.
  source       String
  learnedAt    DateTime  @default(now())

  @@unique([characterId, skillKey])
  @@index([characterId])
  @@index([characterId, isEquipped])
}

/// Phase 11.6.B — Audit log cho mỗi attempt Tribulation/Tâm Ma.
/// Server-authoritative deterministic kiếp:
///   - `tribulationKey` ref `TRIBULATIONS` trong `packages/shared/src/tribulation.ts`.
///   - `fromRealmKey`/`toRealmKey` snapshot (catalog có thể đổi sau).
///   - `success` true → realm đã advance + reward đã grant qua `CurrencyLedger.TRIBULATION_REWARD`.
///   - `success` false → `expLoss` áp dụng (`computeTribulationFailurePenalty`),
///     `cooldownAt` set vào `Character.tribulationCooldownAt`, optional Tâm Ma
///     debuff (`taoMaActive=true` + `taoMaExpiresAt`).
///   - `taoMaRoll` = RNG snapshot cho replay determinism.
///   - `attemptIndex` = thứ tự attempt cho transition này (1..N).
/// Idempotency: KHÔNG có natural unique key — caller phải debounce. Mỗi attempt
/// = 1 row mới (audit replay). Wipe cascade khi character xoá.
model TribulationAttemptLog {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tribulationKey  String
  fromRealmKey    String
  toRealmKey      String
  /// `TribulationSeverity` ∈ {minor, major, heavenly, saint}.
  severity        String
  /// `TribulationType` ∈ {lei, phong, bang, hoa, tam}.
  type            String
  success         Boolean
  wavesCompleted  Int
  totalDamage     Int
  finalHp         Int
  hpInitial       Int
  /// EXP snapshot trước attempt (BigInt, có thể vượt Number.MAX_SAFE_INTEGER).
  expBefore       BigInt
  /// EXP sau attempt — success: `expBefore - cost(stage9) + bonus`; fail:
  /// `computeTribulationFailurePenalty(...).expAfter`.
  expAfter        BigInt
  /// Nếu fail: `expBefore - expAfter`. Nếu success: 0 (không loss).
  expLoss         BigInt    @default(0)
  /// Tâm Ma debuff trigger (chỉ khi fail + RNG roll trúng).
  taoMaActive     Boolean   @default(false)
  taoMaExpiresAt  DateTime?
  /// Cooldown gate cho retry (chỉ khi fail).
  cooldownAt      DateTime?
  /// Reward — chỉ set khi success.
  linhThachReward Int       @default(0)
  expBonusReward  BigInt    @default(0)
  titleKeyReward  String?
  attemptIndex    Int
  /// RNG roll [0,1] cho `taoMaDebuffChance` check; persist cho replay.
  taoMaRoll       Float
  createdAt       DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([tribulationKey, createdAt])
}

/// Phase 11.8.B Buff MVP — duration-based buff/debuff persistence.
/// 1 row per (`characterId`, `buffKey`). `BuffService.applyBuff` dùng upsert:
///   - non-stackable: refresh `expiresAt` (catalog `BuffDef.stackable=false`).
///   - stackable: increment `stacks` capped tại `BuffDef.maxStacks` + refresh
///     `expiresAt`.
/// `BuffService.removeBuff` xóa row explicit. `BuffService.pruneExpired(now)`
/// xóa row có `expiresAt <= now` (cron sweep). `BuffService.listActive(charId,
/// now)` auto-prune trước khi return. `BuffService.getMods(charId, now)` rely
/// vào `composeBuffMods(activeBuffs)` từ `packages/shared/src/buffs.ts`.
///
/// Source ref `BuffSource` ∈ {pill, sect_aura, event, equipment, skill, talent,
/// boss_skill, tribulation}. Không enum để giữ catalog flexible (catalog có
/// thể mở rộng source mới mà không cần migration).
///
/// Wire FUTURE PR (out of scope 11.8.B):
///   - tribulation FAIL Tâm Ma → `applyBuff('debuff_taoma','tribulation')`.
///   - alchemy pill consume → `applyBuff('buff_pill_*', 'pill')`.
///   - skill DOT/CC → applyBuff('debuff_*', 'skill')` trong combat tick.
///   - `composeBuffMods` wire vào `CharacterStatService.computeStats` để stat
///     mod (atk/def/hpMax/mpMax/spirit) áp dụng vào combat + cultivation tick.
model CharacterBuff {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `BUFFS` trong `packages/shared/src/buffs.ts`.
  buffKey     String
  /// Stack count hiện tại (1..`def.maxStacks`). Non-stackable luôn = 1.
  stacks      Int       @default(1)
  /// `BuffSource` snapshot — audit nguồn gốc (catalog có thể đổi sau).
  source      String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@unique([characterId, buffKey])
  @@index([expiresAt])
  @@index([characterId, expiresAt])
}

/// Phase 11.7.B Talent (Thần Thông) MVP — passive/active talent persistence.
/// 1 row per (`characterId`, `talentKey`); composite UNIQUE đảm bảo mỗi
/// character học mỗi talent tối đa 1 lần. Talent point budget tính từ realm
/// order qua `computeTalentPointBudget(currentRealmOrder)` (3 realm = 1 điểm
/// ngộ đạo); spent points = sum `talentPointCost` of learned rows.
///
/// Wire FUTURE PR (out of scope 11.7.B):
///   - `composePassiveTalentMods` vào `CharacterStatService.computeStats`
///     → atk/def/hpMax/mpMax/spirit + drop/exp multiplier + element damage_bonus.
///   - Active talent ("thần thông") execution `useActiveTalent` qua mp
///     consume + cooldown turns enforce trong combat tick (Phase 11.7.C).
model CharacterTalent {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `TALENTS` trong `packages/shared/src/talents.ts`.
  talentKey   String
  learnedAt   DateTime  @default(now())

  @@unique([characterId, talentKey])
  @@index([characterId, learnedAt])
}

/// Phase 11.9.B Title (Danh hiệu) MVP — title ownership persistence.
/// 1 row per (`characterId`, `titleKey`); composite UNIQUE đảm bảo idempotent
/// `unlockTitle`. `Character.title String?` đã tồn tại từ phase 0 — đó là
/// field "equipped title" (chỉ 1 title slot tại 1 thời điểm). Bảng này
/// persist **danh sách title đã unlock** cho character; `equipTitle` validate
/// ownership từ bảng này trước khi set `Character.title`.
///
/// `source` là `TitleSource` snapshot ('realm_milestone' | 'achievement' |
/// 'sect_rank' | 'event' | 'donation' | 'element_mastery'). Catalog có thể
/// đổi sau nên không enum.
///
/// Wire FUTURE PR (out of scope 11.9.B):
///   - auto-grant trên realm breakthrough → `unlockTitle('realm_*', 'realm_milestone')`.
///   - auto-grant trên achievement complete → `unlockTitle(..., 'achievement')`.
///   - `composeTitleMods([equipped])` wire vào `CharacterStatService.computeStats`
///     cho flavor stat bonus (rare ≤ +2%, mythic ≤ +15%).
model CharacterTitleUnlock {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// Khoá tham chiếu `TITLES` trong `packages/shared/src/titles.ts`.
  titleKey    String
  /// `TitleSource` snapshot — audit nguồn unlock.
  source      String
  unlockedAt  DateTime  @default(now())

  @@unique([characterId, titleKey])
  @@index([characterId, unlockedAt])
}

enum MissionPeriod {
  DAILY
  WEEKLY
  ONCE
}

/// Tiến độ nhiệm vụ của từng character theo catalog tĩnh (`packages/shared/src/missions.ts`).
/// Mỗi (character, missionKey) có 1 hàng; cron reset sẽ đưa `currentAmount=0`,
/// `claimed=false`, cập nhật `windowEnd` cho DAILY/WEEKLY. Mission `ONCE` không reset.
model MissionProgress {
  id            String        @id @default(cuid())
  characterId   String
  character     Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  missionKey    String
  period        MissionPeriod
  currentAmount Int           @default(0)
  goalAmount    Int
  claimed       Boolean       @default(false)
  claimedAt     DateTime?
  startedAt     DateTime      @default(now())
  /// Mốc cuối của cửa sổ hiện tại (DAILY/WEEKLY). null với ONCE.
  windowEnd     DateTime?
  updatedAt     DateTime      @updatedAt

  @@unique([characterId, missionKey])
  @@index([characterId, claimed])
  @@index([period, windowEnd])
}

model Mail {
  id               String    @id @default(cuid())
  recipientId      String
  recipient        Character @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  senderName       String    @default("Thiên Đạo Sứ Giả")
  subject          String
  body             String
  rewardLinhThach  BigInt    @default(0)
  rewardTienNgoc   Int       @default(0)
  rewardExp        BigInt    @default(0)
  /// JSON [{ itemKey, qty }]
  rewardItems      Json      @default("[]")
  readAt           DateTime?
  claimedAt        DateTime?
  expiresAt        DateTime?
  /// userId của admin đã gửi (null cho hệ thống / script).
  createdByAdminId String?
  createdAt        DateTime  @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, claimedAt])
  @@index([recipientId, readAt])
  @@index([expiresAt])
}

model InventoryItem {
  id           String     @id @default(cuid())
  characterId  String
  character    Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey      String
  qty          Int        @default(1)
  equippedSlot EquipSlot?
  /// Phase 11.4.B Gem MVP — danh sách gemKey đã khảm theo thứ tự slot.
  /// Capacity tối đa = `socketCapacityForQuality(item.quality)` (PHAM=0,
  /// LINH=1, HUYEN=2, TIEN=3, THAN=4) enforce ở `GemService.socketGem`
  /// server-authoritative. Item non-equipment / chưa khảm giữ `[]`.
  sockets      String[]   @default([])
  /// Phase 11.5.B Refine MVP — cấp luyện khí 0..15 (`REFINE_MAX_LEVEL`).
  /// Stat multiplier = `getRefineStatMultiplier(refineLevel)` áp dụng lên
  /// `bonuses` + socket bonus của trang bị khi tính `equipBonus()`.
  /// Item non-equipment / chưa luyện giữ `0`. Server-authoritative qua
  /// `RefineService.refineEquipment` (no client mutation).
  refineLevel  Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([characterId, equippedSlot])
  @@index([characterId, itemKey])
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model Listing {
  id           String        @id @default(cuid())
  sellerId     String
  itemKey      String
  itemKind     String
  qty          Int
  pricePerUnit BigInt
  status       ListingStatus @default(ACTIVE)
  buyerId      String?
  createdAt    DateTime      @default(now())
  soldAt       DateTime?

  @@index([status, itemKind])
  @@index([status, itemKey])
  @@index([sellerId, status])
}

model Sect {
  id                String      @id @default(cuid())
  name              String      @unique
  description       String      @default("")
  level             Int         @default(1)
  treasuryLinhThach BigInt      @default(0)
  leaderId          String?     @unique
  characters        Character[]
  createdAt         DateTime    @default(now())
}

enum ChatChannel {
  WORLD
  SECT
}

model ChatMessage {
  id         String      @id @default(cuid())
  channel    ChatChannel
  /// scopeKey: with WORLD = 'world'; with SECT = sectId
  scopeKey   String
  senderId   String
  senderName String
  text       String
  createdAt  DateTime    @default(now())

  @@index([channel, scopeKey, createdAt])
}

enum BossStatus {
  ACTIVE
  DEFEATED
  EXPIRED
}

model WorldBoss {
  id          String     @id @default(cuid())
  bossKey     String
  name        String
  level       Int
  maxHp       BigInt
  currentHp   BigInt
  status      BossStatus @default(ACTIVE)
  spawnedAt   DateTime   @default(now())
  expiresAt   DateTime
  defeatedAt  DateTime?
  rewardTotal BigInt     @default(0)

  damages BossDamage[]

  @@index([status, spawnedAt])
}

model BossDamage {
  id            String    @id @default(cuid())
  bossId        String
  boss          WorldBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  characterId   String
  characterName String
  totalDamage   BigInt    @default(0)
  hits          Int       @default(0)
  lastHitAt     DateTime  @default(now())

  @@unique([bossId, characterId])
  @@index([bossId, totalDamage])
}

enum EncounterStatus {
  ACTIVE
  WON
  LOST
  ABANDONED
}

enum CurrencyKind {
  LINH_THACH
  TIEN_NGOC
}

/// Audit trail mọi mutation của linhThach / tienNgoc (Phase 4-8). Một dòng = một
/// thao tác đổi tiền của 1 character. `delta` có dấu (âm = trừ).
model CurrencyLedger {
  id          String       @id @default(cuid())
  characterId String
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  currency    CurrencyKind
  delta       BigInt
  reason      String
  refType     String?
  refId       String?
  meta        Json         @default("{}")
  /// Nếu thao tác do admin/MOD thực hiện (vd ADMIN_GRANT, ADMIN_TOPUP_APPROVE).
  actorUserId String?
  createdAt   DateTime     @default(now())

  @@index([characterId, createdAt])
  @@index([reason, createdAt])
  @@index([refType, refId])
  @@index([actorUserId, createdAt])
}

model Encounter {
  id          String          @id @default(cuid())
  characterId String
  dungeonKey  String
  status      EncounterStatus @default(ACTIVE)
  /// JSON state: { monsterIndex, monsterHp, lastTurn }
  state       Json            @default("{}")
  /// JSON list of log lines [{ side, text, ts }]
  log         Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([characterId, status])
}

model GiftCode {
  id               String               @id @default(cuid())
  /// Normalized upper-case, unique trên toàn hệ.
  code             String               @unique
  rewardLinhThach  BigInt               @default(0)
  rewardTienNgoc   Int                  @default(0)
  rewardExp        BigInt               @default(0)
  /// JSON [{ itemKey, qty }]
  rewardItems      Json                 @default("[]")
  /// null = không giới hạn số lần redeem toàn server (vẫn chặn 1 user 1 lần).
  maxRedeems       Int?
  redeemCount      Int                  @default(0)
  expiresAt        DateTime?
  revokedAt        DateTime?
  createdByAdminId String?
  createdAt        DateTime             @default(now())
  redemptions      GiftCodeRedemption[]

  @@index([expiresAt])
  @@index([revokedAt])
}

model GiftCodeRedemption {
  id          String   @id @default(cuid())
  giftCodeId  String
  giftCode    GiftCode @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)
  userId      String
  characterId String
  redeemedAt  DateTime @default(now())

  @@unique([giftCodeId, userId])
  @@index([userId])
  @@index([characterId])
}

/// Audit trail mọi thay đổi InventoryItem.qty (Phase 9). Một dòng = một thao
/// tác đổi vật phẩm của 1 character. `qtyDelta` có dấu (âm = trừ / mất / dùng).
model ItemLedger {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey     String
  /// Có dấu: dương khi grant (boss/mail/giftcode/shop/mission), âm khi consume (use/sell).
  qtyDelta    Int
  reason      String
  refType     String?
  refId       String?
  meta        Json      @default("{}")
  /// Nếu thao tác do admin thực hiện (vd ADMIN_GRANT).
  actorUserId String?
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
  @@index([itemKey, createdAt])
  @@index([reason, createdAt])
  @@index([refType, refId])
  @@index([actorUserId, createdAt])
}

/// Idempotency log cho phần thưởng đăng nhập hằng ngày.
/// Mỗi (character, ngày-local) có tối đa 1 hàng — unique constraint đảm bảo
/// không double-claim. `claimDateLocal` là `YYYY-MM-DD` theo `MISSION_RESET_TZ`
/// (Asia/Ho_Chi_Minh mặc định) để mốc reset trùng với daily mission.
model DailyLoginClaim {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// `YYYY-MM-DD` theo timezone reset; vd "2026-04-29".
  claimDateLocal String
  /// Số linh thạch đã trao tại lần claim này (positive). BigInt để khớp Character.linhThach.
  linhThachDelta BigInt
  /// Số ngày liên tiếp đã claim trước + bao gồm lần này (1 nếu mới hoặc bị gãy chuỗi).
  streakAtClaim  Int
  createdAt      DateTime  @default(now())

  @@unique([characterId, claimDateLocal])
  @@index([characterId, createdAt])
}
