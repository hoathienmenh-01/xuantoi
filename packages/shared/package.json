{
  "name": "@xuantoi/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./realms": {
      "types": "./dist/realms.d.ts",
      "import": "./dist/realms.js",
      "require": "./dist/realms.cjs"
    },
    "./proverbs": {
      "types": "./dist/proverbs.d.ts",
      "import": "./dist/proverbs.js",
      "require": "./dist/proverbs.cjs"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "import": "./dist/enums.js",
      "require": "./dist/enums.cjs"
    },
    "./ws-events": {
      "types": "./dist/ws-events.d.ts",
      "import": "./dist/ws-events.js",
      "require": "./dist/ws-events.cjs"
    },
    "./api-contracts": {
      "types": "./dist/api-contracts.d.ts",
      "import": "./dist/api-contracts.js",
      "require": "./dist/api-contracts.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(shared) lint skipped\"",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
